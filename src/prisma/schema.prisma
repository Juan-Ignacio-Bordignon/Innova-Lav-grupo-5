generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              Int         @id @default(autoincrement())
  nombre          String
  email           String      @unique
  password        String
  rachaActual     Int         @default(0)
  ultimaActividad DateTime?
  creadoEn        DateTime    @default(now())
  progreso        Progreso[]
  favoritos       Favorite[]
  logros          UserLogro[]
  eventos         EventoLog[]  
}

model Modulo {
  id          Int       @id @default(autoincrement())
  nombre      String
  descripcion String
  lecciones   Leccion[]
}

model Leccion {
  id        Int         @id @default(autoincrement())
  titulo    String
  contenido String
  videoUrl  String?
  moduloId  Int
  modulo    Modulo      @relation(fields: [moduloId], references: [id])
  progreso  Progreso[]
  favoritos Favorite[]
  logros    Logro[]     
}

model Progreso {
  id            Int      @id @default(autoincrement())
  userId        Int
  moduloId      Int
  leccionId     Int
  primerIntento DateTime?
  completadoEn  DateTime @default(now())  
  user          User     @relation(fields: [userId], references: [id])
  leccion       Leccion  @relation(fields: [leccionId], references: [id])
}

model Favorite {
  id        Int      @id @default(autoincrement())
  userId    Int
  leccionId Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  leccion   Leccion  @relation(fields: [leccionId], references: [id], onDelete: Cascade)
  @@unique([userId, leccionId])
}

model Logro {
  id          Int         @id @default(autoincrement())
  nombre      String
  descripcion String
  icono       String?
  leccionId   Int?                                               
  leccion     Leccion?    @relation(fields: [leccionId], references: [id])  
  userLogros  UserLogro[]
}

model UserLogro {
  id            Int      @id @default(autoincrement())
  userId        Int
  logroId       Int
  fechaObtenido DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  logro         Logro    @relation(fields: [logroId], references: [id])
  @@unique([userId, logroId])
}


model EventoLog {
  id         Int      @id @default(autoincrement())
  userId     Int?
  evento     String
  properties Json?
  timestamp  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])
}