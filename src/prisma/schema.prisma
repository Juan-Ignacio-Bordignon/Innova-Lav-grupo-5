generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              Int         @id @default(autoincrement())
  nombre          String
  email           String      @unique
  password        String
  interes         String?     @default("Sin definir")
  puntos          Int         @default(0)
  rachaActual     Int         @default(0)
  ultimaActividad DateTime?
  creadoEn        DateTime    @default(now())
  progreso        Progreso[]
  favoritos       Favorite[]
  logros          UserLogro[]
  eventos         EventoLog[]  
}

model Modulo {
  id          Int       @id @default(autoincrement())
  nombre      String
  descripcion String
  lecciones   Leccion[]
  progreso    Progreso[]
}

model Leccion {
  id        Int         @id @default(autoincrement())
  titulo    String
  contenido String
  moduloId  Int
  modulo    Modulo      @relation(fields: [moduloId], references: [id])
  progreso  Progreso[]
  logros    Logro[]   
  ejercicio Ejercicio[]  
}

model Ejercicio {
  id                  Int      @id @default(autoincrement())
  lessonId            Int
  titulo              String
  contenidoMultimedia String
  leccion             Leccion  @relation(fields: [lessonId], references: [id])
  progreso  Progreso[]
  favoritos Favorite[]
}

model Progreso {
  id            Int      @id @default(autoincrement())
  userId        Int
  moduloId      Int
  leccionId     Int
  ejercicioId   Int
  errores       Int      @default(0)
  puntos        Int      @default(0)
  primerIntento DateTime @default(now())
  completadoEn  DateTime?
  user          User     @relation(fields: [userId], references: [id])
  modulo        Modulo   @relation(fields: [moduloId], references: [id])
  leccion       Leccion  @relation(fields: [leccionId], references: [id])
  ejercicio     Ejercicio @relation(fields: [ejercicioId], references: [id])
}

model Favorite {
  id          Int       @id @default(autoincrement())
  userId      Int
  ejercicioId Int
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  ejercicio   Ejercicio @relation(fields: [ejercicioId], references: [id], onDelete: Cascade)
  @@unique([userId, ejercicioId])
}

model Logro {
  id          Int         @id @default(autoincrement())
  nombre      String
  descripcion String
  icono       String?
  leccionId   Int?                                               
  leccion     Leccion?    @relation(fields: [leccionId], references: [id])  
  userLogros  UserLogro[]
}

model UserLogro {
  id            Int      @id @default(autoincrement())
  userId        Int
  logroId       Int
  fechaObtenido DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  logro         Logro    @relation(fields: [logroId], references: [id])
  @@unique([userId, logroId])
}

model EventoLog {
  id         Int      @id @default(autoincrement())
  userId     Int?
  evento     String
  properties Json?
  timestamp  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])
}